# TradeMirror OS — environment variables
#
# Copy this file to `.env.local` and fill in your Supabase project credentials.
# When BOTH variables are present, the app talks to Supabase. If either is
# missing, the app falls back to in-browser localStorage (demo mode) so the
# UI stays usable without any backend.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJI...your-anon-public-key...
